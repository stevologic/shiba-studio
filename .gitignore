# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# GrokDesk runtime state — never commit (contains API keys, OAuth tokens, chat history)
/data/
/uploads/
/terminals/
/.worktrees/
/mcps/

# runtime logs and automation artifacts
*.log
periodic_log.txt

# local-only Claude Code settings
.claude/settings.local.json
